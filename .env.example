# ---------------------------------------------------------------------------
# APEIRON environment configuration
# Copy to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# --- Core ---
# Set APEIRON_ENV=development for local work (relaxed startup checks) or
# APEIRON_ENV=production for a hardened deployment (strict startup checks).
APEIRON_ENV=production
APEIRON_SECRET_KEY=change-me-to-a-long-random-string
APEIRON_API_HOST=0.0.0.0
APEIRON_API_PORT=8000
APEIRON_LOG_LEVEL=INFO

# --- API auth ---
# Shared secret sent by clients in the `X-API-Key` header.
# !! You MUST change this before running. !!
# In production the backend REFUSES to start while this is empty or left as
# the placeholder below. In development, leaving it as the placeholder simply
# disables auth and logs a warning (convenient for local testing only).
APEIRON_API_KEY=change-this-before-running

# --- CORS ---
# Comma-separated list of browser origins allowed to call the API.
# Wildcards ("*") are rejected in production. Adjust to your real frontend URL.
APEIRON_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database ---
# Default uses SQLite inside the data volume. For Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg2://apeiron:apeiron@db:5432/apeiron
DATABASE_URL=sqlite:////data/apeiron.sqlite3

# --- Broker / queue (Redis) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Storage paths (inside containers) ---
APEIRON_DATA_DIR=/data
APEIRON_UPLOAD_DIR=/data/uploads
APEIRON_DUMP_DIR=/data/dumps
APEIRON_REPORT_DIR=/data/reports
APEIRON_RULES_DIR=/data/rules_generated
APEIRON_BUILTIN_RULES_DIR=/app/rules

# --- Analysis engine ---
# Max emulation time per sample in seconds.
APEIRON_EMULATION_TIMEOUT=60
# Max upload size in bytes (default 64 MiB).
APEIRON_MAX_UPLOAD_BYTES=67108864
# Enable Qiling user-mode emulation. If disabled or unavailable, falls back to static analysis.
APEIRON_ENABLE_EMULATION=true
# Path to Qiling rootfs (mount your own from the qilingframework/rootfs repo).
APEIRON_QILING_ROOTFS=/data/rootfs
# Hide virtualization artifacts from the guest to reduce sandbox-evasion.
APEIRON_ANTI_EVASION=true

# --- Frontend ---
# Base URL the browser uses to reach the API (proxied by nginx in compose).
VITE_API_BASE=/api
VITE_WS_BASE=/ws
